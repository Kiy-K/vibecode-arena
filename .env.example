# OpenRouter API Key - get one at https://openrouter.ai/keys
# Used for both AI chat and component evaluation
OPENROUTER_API_KEY=sk-or-...

# E2B API Key - get one at https://e2b.dev
E2B_API_KEY=e2b_...

# Worker URL - URL of the Cloudflare Worker with Durable Objects
# In dev: not needed (defaults to http://localhost:8788)
# In prod: set to your deployed worker URL
WORKER_URL=https://vibecode-arena.your-subdomain.workers.dev
