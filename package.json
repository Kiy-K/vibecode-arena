{
	"name": "vibecode-arena",
	"private": true,
	"version": "0.1.0",
	"description": "Competitive AI-assisted coding game with E2B sandboxes",
	"author": "Filip Brebera <filip@bxxf.dev>",
	"repository": {
		"type": "git",
		"url": "https://github.com/bxxf/vibecode-arena"
	},
	"type": "module",
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:worker": "wrangler dev --config wrangler.worker.toml",
		"dev:all": "concurrently \"bun run dev\" \"bun run dev:worker\"",
		"build": "vite build",
		"build:worker": "esbuild worker/src/index.ts --bundle --format=esm --outfile=worker/dist/index.js --platform=neutral --conditions=workerd --external:cloudflare:*",
		"deploy:worker": "wrangler deploy --config wrangler.worker.toml",
		"deploy:app": "vite build && wrangler pages deploy",
		"preview": "vite preview",
		"postinstall": "patch-package",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "svelte-kit sync && vitest run",
		"test:watch": "svelte-kit sync && vitest",
		"test:coverage": "svelte-kit sync && vitest run --coverage",
		"test:e2e:quick": "concurrently -k -s first -n 'vite,worker,test' --hide 'vite,worker' 'E2E_SKIP_SANDBOX=true bun run dev' 'bun run dev:worker' 'wait-on -q tcp:5173 tcp:8788 && E2E_SKIP_SANDBOX=true playwright test --grep-invert @sandbox'",
		"test:e2e:sandbox": "concurrently -k -s first -n 'vite,worker,test' --hide 'vite,worker' 'bun run dev' 'bun run dev:worker' 'wait-on -q tcp:5173 tcp:8788 && playwright test --grep @sandbox'",
		"test:e2e:ui": "concurrently -k -n 'vite,worker,ui' 'E2E_SKIP_SANDBOX=true bun run dev' 'bun run dev:worker' 'wait-on tcp:5173 tcp:8788 && playwright test --ui --grep-invert @sandbox'",
		"test:e2e:ui:sandbox": "concurrently -k -n 'vite,worker,ui' 'bun run dev' 'bun run dev:worker' 'wait-on tcp:5173 tcp:8788 && playwright test --ui --grep @sandbox'",
		"validate": "npm run check && npm run lint && npm run format:check"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20241205.0",
		"@eslint/js": "^9.17.0",
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/svelte": "^5.2.9",
		"@types/canvas-confetti": "^1.9.0",
		"@types/node": "^22.10.0",
		"@vitest/coverage-v8": "^4.0.15",
		"@vitest/ui": "^4.0.15",
		"concurrently": "^9.1.2",
		"esbuild": "^0.24.0",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"jsdom": "^27.2.0",
		"lint-staged": "^16.2.7",
		"patch-package": "^8.0.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.18.0",
		"vite": "^7.2.2",
		"vitest": "^4.0.15",
		"wait-on": "^9.0.3",
		"wrangler": "^4.53.0"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.53",
		"@ai-sdk/openai": "^2.0.77",
		"@ai-sdk/svelte": "^3.0.106",
		"@anthropic-ai/sdk": "^0.71.1",
		"@openrouter/ai-sdk-provider": "^1.4.0",
		"@sitnik/nanoid": "npm:@jsr/sitnik__nanoid@^5.1.5",
		"ai": "^5.0.106",
		"bits-ui": "^2.14.4",
		"canvas-confetti": "^1.9.4",
		"e2b": "^2.8.3",
		"highlight.js": "^11.11.1",
		"isomorphic-dompurify": "^2.33.0",
		"nanoid": "^5.1.6",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"svelte-highlight": "^7.9.0",
		"valibot": "^1.2.0"
	},
	"lint-staged": {
		"*.{ts,js,svelte}": [
			"eslint --fix --max-warnings 0 --no-warn-ignored",
			"prettier --write"
		],
		"*.{json,md,css,html}": [
			"prettier --write"
		]
	}
}
